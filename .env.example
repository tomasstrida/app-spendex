# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
SESSION_SECRET=change-this-in-production

# Database (Railway Volume v produkci)
# DB_PATH=/data/data.db
# SESSION_DB_PATH=/data/sessions.db

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Přístup do aplikace: čárkou oddělené e-maily administrátorů.
# Tyto účty jsou vždy povolené a mohou spravovat allowlist v Nastavení.
# Když není nastaveno, fallback označí všechny stávající uživatele jako adminy.
ADMIN_EMAILS=

# Brevo
BREVO_API_KEY=
FROM_EMAIL=noreply@spendex.app
FROM_NAME=Spendex

# --- Zálohy DB na Cloudflare R2 ---
# Bez těchto čtyř se cron záloha NEAKTIVUJE (lokální dev tím pádem nezálohuje).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Volitelné:
BACKUP_ALERT_EMAIL=tomas.strida@gmail.com
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=30
# E-mail při ÚSPĚŠNÉ záloze byl ZRUŠEN (úspěch se jen loguje do tabulky backup_log).
# Heartbeat: druhý cron ověří, že je v DB čerstvá úspěšná záloha; když ne → warning e-mail.
BACKUP_CHECK_CRON=0 5 * * *
# Okno "čerstvé zálohy" v hodinách (default 3 = 2 h po záloze + rezerva):
BACKUP_MAX_AGE_HOURS=3

# E-mailový import (Cloudflare Email Worker → webhook)
# Sdílený secret mezi Cloudflare Workerem a webhookem (vygeneruj: openssl rand -hex 24)
EMAIL_WEBHOOK_SECRET=zmen-na-nahodny-dlouhy-retezec
# Gmail adresa, ze které se přeposílají AirBank notifikace (whitelist odesílatele)
EMAIL_ALLOWED_SENDER=tvuj-gmail@gmail.com

# --- Push notifikace (Web Push / VAPID) ---
# Vygeneruj klíče: npx web-push generate-vapid-keys
# Public key se posílá do prohlížeče, private MUSÍ zůstat tajný (jen server).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tomas.strida@gmail.com
